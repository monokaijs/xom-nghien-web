# Local web configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=local-dev-nextauth-secret-change-before-production
SESSION_SECRET=local-dev-session-secret-change-before-production

# Optional: required for Steam sign-in and Steam API-backed features
STEAM_API_KEY=
STEAM_WEB_API_KEY=

# Local MySQL container
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=xom
DB_PASSWORD=xom-local-password
DB_NAME=cs2db
MYSQL_ROOT_PASSWORD=xom-local-root-password

# MatchZy demo ingestion (keep the token secret in real environments)
MATCHZY_UPLOAD_TOKEN=change-me-to-a-long-random-token
MATCH_DEMO_STORAGE_DIR=/absolute/path/to/xom-nghien-web/storage/match-demos

# Optional inventory simulator integration
INVENTORY_PUBLIC_URL=http://localhost:3001
INVENTORY_INTERNAL_URL=http://localhost:3001
XN_INV_API_AUTH_KEY=
