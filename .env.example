# Local web configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=local-dev-nextauth-secret-change-before-production
SESSION_SECRET=local-dev-session-secret-change-before-production
NEXT_PUBLIC_SUPPORT_EMAIL=

# Optional: required for Steam sign-in and Steam API-backed features
STEAM_API_KEY=
STEAM_WEB_API_KEY=

# Optional web OAuth login providers
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Discord activity bot (required for `pnpm dev:bot` or the Compose discord profile)
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_GUILD_ID=
WEB_PUBLIC_URL=http://localhost:3000
DISCORD_BOT_HEALTH_PORT=3100

# Browser-to-browser voice rooms (PeerJS Cloud signaling; no hosted signaling/socket service)
VOICE_ENABLED=true
VOICE_GUEST_COOKIE_SECRET=local-dev-voice-guest-cookie-secret-change-before-production
VOICE_ROOM_CODE_SECRET=local-dev-voice-room-code-secret-change-before-production
STUN_URLS=stun:stun.l.google.com:19302

# Optional coturn fallback. Leave TURN_URLS empty when TURN is not deployed.
TURN_URLS=
TURN_SHARED_SECRET=local-dev-turn-secret-change-before-production
TURN_REALM=localhost
TURN_EXTERNAL_IP=127.0.0.1
TURN_MIN_PORT=49160
TURN_MAX_PORT=49200

# Local MySQL container
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=xom
DB_PASSWORD=xom-local-password
DB_NAME=cs2db
MYSQL_ROOT_PASSWORD=xom-local-root-password

# Cached game-server status service (web requests never probe game servers directly)
SERVER_HEARTBEATS_URL=http://127.0.0.1:3200
SERVER_HEARTBEATS_PORT=3200
SERVER_HEARTBEATS_INTERVAL_MS=15000
VALHEIM_PLAYFAB_TITLE_ID=6E223
VALHEIM_PLAYFAB_CUSTOM_ID=xomnghien-heartbeat-v1

# MatchZy demo ingestion (keep the token secret in real environments)
MATCHZY_UPLOAD_TOKEN=change-me-to-a-long-random-token
MATCH_DEMO_STORAGE_DIR=/absolute/path/to/xom-nghien-web/storage/match-demos
MATCHZY_DATABASE_PUBLIC_HOST=

# Optional inventory simulator integration
INVENTORY_PUBLIC_URL=http://localhost:3001
INVENTORY_INTERNAL_URL=http://localhost:3001
XN_INV_API_AUTH_KEY=
