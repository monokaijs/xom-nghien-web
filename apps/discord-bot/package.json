{
  "name": "@xom/discord-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc --noEmit -p tsconfig.json && esbuild src/index.ts --bundle --platform=node --format=esm --external:discord.js --external:drizzle-orm --external:mysql2 --outfile=dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@xom/db": "workspace:*",
    "discord.js": "14.27.0",
    "drizzle-orm": "^0.44.7",
    "mysql2": "^3.15.3"
  },
  "devDependencies": {
    "@types/node": "^22.18.0",
    "@xom/tsconfig": "workspace:*",
    "esbuild": "^0.25.12",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
