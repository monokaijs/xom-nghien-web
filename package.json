{
  "name": "xom-nghien",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=11.0.9"
  },
  "scripts": {
    "dev": "turbo run dev --filter=!@xom/discord-bot",
    "dev:bot": "pnpm --filter @xom/discord-bot dev",
    "dev:services": "docker compose -f compose.dev.yml up -d",
    "dev:services:down": "docker compose -f compose.dev.yml down",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "turbo": "^2.6.1",
    "typescript": "^5.9.3"
  }
}
