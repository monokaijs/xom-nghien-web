{
  "name": "@xom/spawner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "tsx src/main.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.9",
    "@nestjs/core": "^11.1.9",
    "@nestjs/platform-express": "^11.1.9",
    "@xom/db": "workspace:*",
    "@xom/game-config": "workspace:*",
    "@xom/queue": "workspace:*",
    "bullmq": "^5.64.1",
    "gamedig": "^5.3.2",
    "mysql2": "^3.15.3",
    "node-ssh": "^13.2.1",
    "rcon": "^1.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ssh2-sftp-client": "^12.0.1",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/gamedig": "^5.0.3",
    "@types/node": "^22.18.0",
    "@types/ssh2-sftp-client": "^9.0.6",
    "@xom/tsconfig": "workspace:*",
    "typescript": "^5.9.3"
  }
